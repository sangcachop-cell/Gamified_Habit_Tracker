  "phaserUsage": {
    "_comment": "Reference snippets for loading and animating assets in Phaser 3",
    "loadSpritesheet": "this.load.spritesheet(entry.key, 'asset/Modern tiles/' + entry.path, { frameWidth: entry.frameWidth, frameHeight: entry.frameHeight });",
    "loadImage": "this.load.image(entry.key, 'asset/Modern tiles/' + entry.path);",
    "createAnim": "this.anims.create({ key: anim.key, frames: this.anims.generateFrameNumbers(entry.key, { start: anim.start, end: anim.end }), frameRate: anim.frameRate, repeat: anim.repeat });",
    "playAnim": "sprite.anims.play('adam_run_down', true);",
    "notes": [
      "Character frameHeight is 32 (2 tiles tall) even for 16x16 tile size packs.",
      "Animation frame ranges (start/end) are best-guess based on image dimensions — verify against actual sprite layout.",
      "Tileset images are loaded as images, not spritesheets; use Tiled JSON maps for full tilemap support.",
      "Interior sheets are very tall (89+ rows); consider slicing or using Tiled map integration."
    ]
  }
