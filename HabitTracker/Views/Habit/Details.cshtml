@model HabitTracker.Models.Habit

<div class="container mt-4">

    <h3>Habit Details</h3>

    <div class="card p-4 shadow-sm">

        <h4>
            <img src="~/icons/@Model.Icon" width="40" />
            @Model.Name
        </h4>

        <p><b>Description:</b> @Model.Description</p>

        <p><b>Frequency:</b> @Model.Frequency</p>

        <p>
            <b>Reminder:</b>
            @(Model.ReminderTime?.ToString(@"hh\:mm") ?? "None")
        </p>

        <p>
            <b>Deadline:</b>
            @(Model.Deadline?.ToString("yyyy-MM-dd") ?? "None")
        </p>

        <p><b>Streak:</b> 🔥 @Model.Streak days</p>

        <p><b>XP Reward:</b> +@Model.XPReward</p>

        <a href="/Habit/Index" class="btn btn-secondary mt-3">
            Back
        </a>

    </div>

</div>