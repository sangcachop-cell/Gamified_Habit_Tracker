@model List<HabitTracker.Models.Habit>

<div class="container mt-4">

    <h2 class="mb-4">📊 Dashboard</h2>

    <!-- 🔥 PROGRESS -->
    <div class="card p-3 mb-4 shadow-sm">
        <h5>Today's Progress</h5>

        <div class="progress mt-2" style="height: 25px;">
            <div class="progress-bar bg-success"
                 style="width:@ViewBag.Percent%">
                @ViewBag.Percent%
            </div>
        </div>
    </div>

    <!-- 📋 HABIT LIST -->
    <div class="card p-3 shadow-sm">
        <h5>Your Habits Today</h5>

        @foreach (var habit in Model)
        {
            var isDone = habit.LastCompletedDate == DateTime.Today;

            <div class="d-flex justify-content-between border-bottom py-2">
                <div>
                    <b>@habit.Name</b><br />
                    🔥 @habit.Streak ngày
                </div>

                <div>
                    @if (isDone)
                    {
                        <span class="badge bg-success">Done</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pending</span>
                    }
                </div>
            </div>
        }
    </div>

    <!-- 🏆 BEST HABIT (THÊM Ở ĐÂY) -->
    <div class="card p-3 mt-4 shadow-sm">
        <h5>🏆 Best Habit</h5>

        @{
            var best = Model.OrderByDescending(h => h.Streak).FirstOrDefault();
        }

        @if (best != null)
        {
            <p>
                <b>@best.Name</b> <br />
                🔥 Streak: @best.Streak ngày
            </p>
        }
        else
        {
            <p class="text-muted">Chưa có dữ liệu</p>
        }
    </div>

</div>