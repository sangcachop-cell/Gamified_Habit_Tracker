@{
    ViewData["Title"] = "Leaderboard";
    var topXP = ViewBag.TopXP as List<HabitTracker.Models.User>;
    var topStreak = ViewBag.TopStreak as List<HabitTracker.Models.User>;
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --violet: #5c3dde;
        --gold: #f0b429;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4 {
        font-family: "Syne",sans-serif
    }

    .lb-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 36px;
        color: white;
        margin-bottom: 32px;
        text-align: center;
        position: relative;
        overflow: hidden
    }

        .lb-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 30% 50%,rgba(92,61,222,.4),transparent 60%),radial-gradient(ellipse at 70% 50%,rgba(240,180,41,.25),transparent 60%);
            pointer-events: none
        }

        .lb-hero h2 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -1px;
            position: relative;
            z-index: 2;
            margin-bottom: 6px
        }

        .lb-hero p {
            color: rgba(255,255,255,.6);
            position: relative;
            z-index: 2;
            font-size: .92rem
        }

    .lb-tabs {
        display: flex;
        gap: 0;
        background: white;
        border-radius: 12px;
        padding: 4px;
        border: 1.5px solid rgba(0,0,0,.07);
        width: fit-content;
        margin: 0 auto 28px
    }

    .lb-tab {
        padding: 9px 24px;
        border-radius: 9px;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .88rem;
        cursor: pointer;
        transition: all .2s;
        border: none;
        background: transparent
    }

        .lb-tab.active {
            background: var(--ink);
            color: white
        }

        .lb-tab:not(.active) {
            color: #888
        }

    .lb-panel {
        display: none
    }

        .lb-panel.active {
            display: block
        }
    /* podium */
    .podium {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 12px;
        margin-bottom: 32px
    }

    .pod {
        text-align: center;
        flex: 1;
        max-width: 160px
    }

    .pod-bar {
        border-radius: 14px 14px 0 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-end;
        padding: 16px 12px 12px
    }

    .pod-1 .pod-bar {
        background: linear-gradient(180deg,#f0b429,#e8a000);
        height: 130px
    }

    .pod-2 .pod-bar {
        background: linear-gradient(180deg,#bdbdbd,#9e9e9e);
        height: 100px
    }

    .pod-3 .pod-bar {
        background: linear-gradient(180deg,#cd7f32,#a0622a);
        height: 80px
    }

    .pod-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: rgba(255,255,255,.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        font-weight: 700;
        margin: 0 auto 6px;
        border: 2px solid rgba(255,255,255,.5);
        color: white;
        font-family: "Syne",sans-serif
    }

    .pod-crown {
        font-size: 1.4rem;
        margin-bottom: 4px
    }

    .pod-name {
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .82rem;
        margin-bottom: 2px
    }

    .pod-val {
        font-size: .75rem;
        opacity: .85
    }

    .pod-rank {
        font-size: 1.6rem;
        margin-top: 6px
    }
    /* table */
    .lb-table {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        border: 1.5px solid rgba(0,0,0,.07)
    }

    .lb-row {
        display: grid;
        grid-template-columns: 56px 1fr 110px 110px;
        align-items: center;
        padding: 14px 22px;
        border-bottom: 1px solid #f5f5f5;
        transition: background .2s;
        gap: 8px
    }

        .lb-row:last-child {
            border: none
        }

        .lb-row:hover {
            background: var(--soft)
        }

    .lb-head {
        background: #f8f8f8;
        font-family: "Syne",sans-serif;
        font-size: .73rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #aaa
    }

    .lb-rank-num {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        font-size: 1rem;
        color: #ccc
    }

        .lb-rank-num.gold {
            color: var(--gold)
        }

        .lb-rank-num.silver {
            color: #9e9e9e
        }

        .lb-rank-num.bronze {
            color: #cd7f32
        }

    .lb-user {
        display: flex;
        align-items: center;
        gap: 10px
    }

    .lb-av {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .95rem;
        flex-shrink: 0;
        object-fit: cover
    }

    .lb-uname {
        font-weight: 700;
        font-size: .88rem
    }

    .lb-ulv {
        font-size: .75rem;
        color: #aaa
    }

    .lb-xp-val {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        color: var(--violet);
        font-size: .95rem
    }

    .lb-streak-val {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        color: var(--rose);
        font-size: .95rem
    }

    @@media(max-width:700px) {
        .lb-row {
            grid-template-columns: 40px 1fr 80px
        }

        .lb-xp-head, .lb-streak-extra {
            display: none
        }
    }
</style>

<div style="padding:8px 0 48px">

    <div class="lb-hero">
        <h2>🏆 Bảng xếp hạng</h2>
        <p>Top người dùng xuất sắc nhất trong cộng đồng</p>
    </div>

    <!-- Tabs -->
    <div style="display:flex;justify-content:center;margin-bottom:28px">
        <div class="lb-tabs">
            <button class="lb-tab active" onclick="switchTab('xp',this)">⚡ Top XP</button>
            <button class="lb-tab" onclick="switchTab('streak',this)">🔥 Top Streak</button>
        </div>
    </div>

    <!-- XP Panel -->
    <div id="panel-xp" class="lb-panel active">
        @if (topXP != null && topXP.Count > 0)
        {
            <!-- Podium top 3 -->
            @if (topXP.Count >= 3)
            {
                <div class="podium">
                    <!-- 2nd -->
                    <div class="pod pod-2">
                        <div class="pod-bar">
                            <div class="pod-avatar">@topXP[1].Username.Substring(0, 1).ToUpper()</div>
                            <div class="pod-name" style="color:white">@topXP[1].Username</div>
                            <div class="pod-val" style="color:rgba(255,255,255,.8)">@topXP[1].XP.ToString("N0") XP</div>
                        </div>
                        <div class="pod-rank">🥈</div>
                    </div>
                    <!-- 1st -->
                    <div class="pod pod-1">
                        <div style="font-size:1.6rem;text-align:center">👑</div>
                        <div class="pod-bar">
                            <div class="pod-avatar">@topXP[0].Username.Substring(0, 1).ToUpper()</div>
                            <div class="pod-name" style="color:white">@topXP[0].Username</div>
                            <div class="pod-val" style="color:rgba(255,255,255,.85)">@topXP[0].XP.ToString("N0") XP</div>
                        </div>
                        <div class="pod-rank">🥇</div>
                    </div>
                    <!-- 3rd -->
                    <div class="pod pod-3">
                        <div class="pod-bar">
                            <div class="pod-avatar">@topXP[2].Username.Substring(0, 1).ToUpper()</div>
                            <div class="pod-name" style="color:white">@topXP[2].Username</div>
                            <div class="pod-val" style="color:rgba(255,255,255,.8)">@topXP[2].XP.ToString("N0") XP</div>
                        </div>
                        <div class="pod-rank">🥉</div>
                    </div>
                </div>
            }

            <div class="lb-table">
                <div class="lb-row lb-head">
                    <span>#</span><span>Người dùng</span><span>XP</span><span>Level</span>
                </div>
                @for (int i = 0; i < topXP.Count; i++)
                {
                    var u = topXP[i];
                    var rc = i == 0 ? "gold" : i == 1 ? "silver" : i == 2 ? "bronze" : "";
                    var ri = i == 0 ? "🥇" : i == 1 ? "🥈" : i == 2 ? "🥉" : (i + 1).ToString();
                    var bgs = new[] { "#fff5d6", "#edeaf5", "#d4f5ef", "#fde8ed", "#e2f5e2", "#f0f4ff", "#fff0f6", "#f0fff4", "#fffde7", "#fce4ec" };
                    var bg = bgs[i % bgs.Length];
                    <div class="lb-row">
                        <span class="lb-rank-num @rc">@ri</span>
                        <div class="lb-user">
                            <div class="lb-av" style="background:@bg">@u.Username.Substring(0, 1).ToUpper()</div>
                            <div><div class="lb-uname">@u.Username</div><div class="lb-ulv">@(u.CurrentStreak > 0 ? $"🔥 {u.CurrentStreak} streak" : "No streak")</div></div>
                        </div>
                        <span class="lb-xp-val">@u.XP.ToString("N0")</span>
                        <span style="font-family:'Syne',sans-serif;font-weight:700;color:#555">Lv.@u.Level</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center;padding:48px;background:white;border-radius:16px;color:#aaa">Chưa có dữ liệu.</div>
        }
    </div>

    <!-- Streak Panel -->
    <div id="panel-streak" class="lb-panel">
        @if (topStreak != null && topStreak.Count > 0)
        {
            <div class="lb-table">
                <div class="lb-row lb-head">
                    <span>#</span><span>Người dùng</span><span>Streak</span><span>XP</span>
                </div>
                @for (int i = 0; i < topStreak.Count; i++)
                {
                    var u = topStreak[i];
                    var rc = i == 0 ? "gold" : i == 1 ? "silver" : i == 2 ? "bronze" : "";
                    var ri = i == 0 ? "🥇" : i == 1 ? "🥈" : i == 2 ? "🥉" : (i + 1).ToString();
                    var bgs = new[] { "#fff5d6", "#edeaf5", "#d4f5ef", "#fde8ed", "#e2f5e2", "#f0f4ff", "#fff0f6", "#f0fff4", "#fffde7", "#fce4ec" };
                    var bg = bgs[i % bgs.Length];
                    <div class="lb-row">
                        <span class="lb-rank-num @rc">@ri</span>
                        <div class="lb-user">
                            <div class="lb-av" style="background:@bg">@u.Username.Substring(0, 1).ToUpper()</div>
                            <div><div class="lb-uname">@u.Username</div><div class="lb-ulv">Level @u.Level</div></div>
                        </div>
                        <span class="lb-streak-val">🔥 @u.CurrentStreak ngày</span>
                        <span class="lb-xp-val">@u.XP.ToString("N0")</span>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align:center;padding:48px;background:white;border-radius:16px;color:#aaa">Chưa có dữ liệu.</div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(id, btn) {
            document.querySelectorAll(".lb-panel").forEach(p => p.classList.remove("active"));
            document.querySelectorAll(".lb-tab").forEach(b => b.classList.remove("active"));
            document.getElementById("panel-" + id).classList.add("active");
            btn.classList.add("active");
        }
    </script>
}
