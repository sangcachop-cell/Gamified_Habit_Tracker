@{
    ViewData["Title"] = "Đổi mật khẩu";
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --violet: #5c3dde;
        --gold: #f0b429;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4 {
        font-family: "Syne",sans-serif
    }

    .cp-wrap {
        max-width: 520px;
        margin: 0 auto;
        padding: 32px 0 64px
    }

    .page-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #888;
        text-decoration: none;
        font-size: .85rem;
        margin-bottom: 24px;
        transition: color .2s
    }

        .page-back:hover {
            color: var(--violet)
        }

    .cp-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 28px 32px;
        color: white;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden
    }

        .cp-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 80% 50%,rgba(92,61,222,.4),transparent 60%);
            pointer-events: none
        }

        .cp-hero h2 {
            font-family: "Syne",sans-serif;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin: 0 0 4px;
            position: relative;
            z-index: 2
        }

        .cp-hero p {
            color: rgba(255,255,255,.55);
            font-size: .88rem;
            margin: 0;
            position: relative;
            z-index: 2
        }

    .glass-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 28px
    }

    .form-field {
        margin-bottom: 20px
    }

        .form-field label {
            font-weight: 600;
            font-size: .83rem;
            color: #444;
            display: block;
            margin-bottom: 7px
        }

    .pw-wrap {
        position: relative
    }

    .form-field input {
        width: 100%;
        padding: 12px 44px 12px 16px;
        border: 1.5px solid rgba(0,0,0,.1);
        border-radius: 10px;
        font-family: "DM Sans",sans-serif;
        font-size: .95rem;
        outline: none;
        transition: border-color .2s,box-shadow .2s;
        background: white
    }

        .form-field input:focus {
            border-color: var(--violet);
            box-shadow: 0 0 0 3px rgba(92,61,222,.08)
        }

    .eye-btn {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        color: #aaa;
        padding: 0;
        line-height: 1
    }

    .strength-bar {
        height: 5px;
        border-radius: 50px;
        margin-top: 8px;
        background: #e8e8e8;
        overflow: hidden
    }

    .strength-fill {
        height: 100%;
        border-radius: 50px;
        transition: width .3s,background .3s
    }

    .strength-label {
        font-size: .73rem;
        color: #aaa;
        margin-top: 4px
    }

    .btn-submit {
        width: 100%;
        padding: 13px;
        background: var(--ink);
        color: white;
        border: none;
        border-radius: 50px;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: background .2s,transform .2s;
        margin-top: 4px
    }

        .btn-submit:hover {
            background: var(--violet);
            transform: translateY(-1px)
        }

    .alert-s {
        background: #d4f5ef;
        color: #006651;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: .88rem;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px
    }

    .alert-e {
        background: #fde8ed;
        color: #c0392b;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: .88rem;
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        gap: 8px
    }

    .rules {
        background: var(--soft);
        border-radius: 10px;
        padding: 14px 16px;
        margin-top: 12px
    }

        .rules p {
            font-size: .8rem;
            font-weight: 700;
            color: #666;
            margin-bottom: 8px
        }

    .rule {
        font-size: .78rem;
        color: #888;
        display: flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 4px
    }

        .rule.ok {
            color: var(--teal)
        }

            .rule.ok::before {
                content: "✓";
                font-weight: 700
            }

        .rule:not(.ok)::before {
            content: "·"
        }
</style>

<div class="cp-wrap">
    <a href="javascript:history.back()" class="page-back">← Quay lại</a>

    <div class="cp-hero">
        <h2>🔐 Đổi mật khẩu</h2>
        <p>Bảo vệ tài khoản với mật khẩu mạnh</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-s">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-e">❌ @TempData["Error"]</div>
    }

    <div class="glass-card">
        <form method="post">
            <div class="form-field">
                <label>Mật khẩu hiện tại</label>
                <div class="pw-wrap">
                    <input type="password" name="oldPassword" id="oldPw" placeholder="••••••••" required />
                    <button type="button" class="eye-btn" onclick="togglePw('oldPw',this)">👁</button>
                </div>
                @if (ViewData.ModelState["oldPassword"]?.Errors.Count > 0)
                {
                    <div style="color:#c0392b;font-size:.8rem;margin-top:4px">@ViewData.ModelState["oldPassword"].Errors[0].ErrorMessage</div>
                }
            </div>

            <div class="form-field">
                <label>Mật khẩu mới</label>
                <div class="pw-wrap">
                    <input type="password" name="newPassword" id="newPw" placeholder="Ít nhất 6 ký tự"
                           required oninput="checkStrength(this.value)" />
                    <button type="button" class="eye-btn" onclick="togglePw('newPw',this)">👁</button>
                </div>
                <div class="strength-bar"><div class="strength-fill" id="strengthFill" style="width:0%"></div></div>
                <div class="strength-label" id="strengthLabel">Nhập mật khẩu để kiểm tra độ mạnh</div>
                @if (ViewData.ModelState["newPassword"]?.Errors.Count > 0)
                {
                    <div style="color:#c0392b;font-size:.8rem;margin-top:4px">@ViewData.ModelState["newPassword"].Errors[0].ErrorMessage</div>
                }
            </div>

            <div class="form-field">
                <label>Xác nhận mật khẩu mới</label>
                <div class="pw-wrap">
                    <input type="password" name="confirmPassword" id="cfPw" placeholder="Nhập lại mật khẩu mới"
                           required oninput="checkMatch()" />
                    <button type="button" class="eye-btn" onclick="togglePw('cfPw',this)">👁</button>
                </div>
                <div class="strength-label" id="matchLabel"></div>
                @if (ViewData.ModelState["confirmPassword"]?.Errors.Count > 0)
                {
                    <div style="color:#c0392b;font-size:.8rem;margin-top:4px">@ViewData.ModelState["confirmPassword"].Errors[0].ErrorMessage</div>
                }
            </div>

            <div class="rules">
                <p>Yêu cầu mật khẩu:</p>
                <div class="rule" id="r1">Ít nhất 6 ký tự</div>
                <div class="rule" id="r2">Có chữ hoa</div>
                <div class="rule" id="r3">Có chữ số</div>
            </div>

            <button type="submit" class="btn-submit" style="margin-top:20px">🔐 Đổi mật khẩu</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function togglePw(id, btn) {
            const i = document.getElementById(id);
            i.type = i.type === 'password' ? 'text' : 'password';
            btn.textContent = i.type === 'password' ? '👁' : '🙈';
        }
        function checkStrength(v) {
            let score = 0;
            if (v.length >= 6) score++;
            if (v.length >= 10) score++;
            if (/[A-Z]/.test(v)) score++;
            if (/[0-9]/.test(v)) score++;
            if (/[^A-Za-z0-9]/.test(v)) score++;
            const pct = score * 20;
            const colors = ['#e8e8e8','#e8436a','#f0b429','#f0b429','#00b89c','#5c3dde'];
            const labels = ['','Rất yếu','Yếu','Trung bình','Mạnh','Rất mạnh'];
            document.getElementById('strengthFill').style.width = pct + '%';
            document.getElementById('strengthFill').style.background = colors[score];
            document.getElementById('strengthLabel').textContent = labels[score] || '';

            document.getElementById('r1').className = 'rule' + (v.length >= 6 ? ' ok' : '');
            document.getElementById('r2').className = 'rule' + (/[A-Z]/.test(v) ? ' ok' : '');
            document.getElementById('r3').className = 'rule' + (/[0-9]/.test(v) ? ' ok' : '');
        }
        function checkMatch() {
            const nv = document.getElementById('newPw').value;
            const cv = document.getElementById('cfPw').value;
            const lbl = document.getElementById('matchLabel');
            if (!cv) { lbl.textContent = ''; return; }
            lbl.textContent = nv === cv ? '✓ Mật khẩu khớp' : '✗ Mật khẩu không khớp';
            lbl.style.color = nv === cv ? '#00b89c' : '#e8436a';
        }
    </script>
}
