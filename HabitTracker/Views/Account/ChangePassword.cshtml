<div class="profile-page">

    <div class="profile-box">

        <h3>Change Password</h3>

        <form method="post" onsubmit="return validateForm()">

            <input type="password"
                   id="oldPass"
                   name="oldPassword"
                   class="form-control"
                   placeholder="Old Password" required />

            <input type="password"
                   id="newPass"
                   name="newPassword"
                   class="form-control mt-2"
                   placeholder="New Password" required />

            <button type="submit" class="btn btn-primary mt-3">
                Update Password
            </button>

        </form>

        @if (ViewBag.Error != null)
        {
            <p class="text-danger mt-2">@ViewBag.Error</p>
        }

        @if (ViewBag.Success != null)
        {
            <script>
                window.onload = () => showToast("✅ Đổi mật khẩu thành công!");
            </script>
        }

        <a href="/Account/Profile" class="btn btn-outline-secondary mt-2">
            Back
        </a>

    </div>

</div>

<div id="toast" class="toast-box"></div>

@section Scripts {
    <script>
        function validateForm() {
            let oldPass = document.getElementById("oldPass");
            let newPass = document.getElementById("newPass");

            if (newPass.value.length < 6) {
                newPass.classList.add("input-error");
                showToast("❌ Mật khẩu phải >= 6 ký tự");
                return false;
            }

            return true;
        }

        function showToast(message) {
            let toast = document.getElementById("toast");
            toast.innerText = message;
            toast.style.display = "block";

            setTimeout(() => {
                toast.style.display = "none";
            }, 2500);
        }
    </script>
}