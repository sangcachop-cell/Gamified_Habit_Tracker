@model HabitTracker.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập — HabitTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: "DM Sans",sans-serif;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr
        }

        h1, h2, h3 {
            font-family: "Syne",sans-serif
        }

        .left-panel {
            background: #0a0a12;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 52px 56px;
            position: relative;
            overflow: hidden
        }

            .left-panel::before {
                content: "";
                position: absolute;
                width: 600px;
                height: 600px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(92,61,222,.3) 0%,transparent 70%);
                top: -200px;
                right: -200px
            }

            .left-panel::after {
                content: "";
                position: absolute;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: radial-gradient(circle,rgba(240,180,41,.2) 0%,transparent 70%);
                bottom: -100px;
                left: -100px
            }

        .brand {
            font-size: 1.4rem;
            font-weight: 800;
            color: white;
            text-decoration: none;
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            gap: 8px
        }

            .brand span {
                color: #f0b429
            }

        .hero-text {
            position: relative;
            z-index: 2
        }

            .hero-text h2 {
                font-size: clamp(2.2rem,4vw,3.2rem);
                font-weight: 800;
                line-height: 1.05;
                letter-spacing: -2px;
                margin-bottom: 16px
            }

            .hero-text p {
                color: rgba(255,255,255,.55);
                font-size: .95rem;
                line-height: 1.7;
                max-width: 380px
            }

        .feature-list {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            gap: 12px
        }

        .feat-item {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,.7);
            font-size: .88rem
        }

        .feat-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .9rem;
            flex-shrink: 0
        }
        /* RIGHT */
        .right-panel {
            background: #f5f3ef;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 52px
        }

        .auth-box {
            width: 100%;
            max-width: 420px
        }

            .auth-box h3 {
                font-size: 1.9rem;
                font-weight: 800;
                letter-spacing: -1.5px;
                margin-bottom: 5px
            }

            .auth-box .subtitle {
                color: #888;
                font-size: .9rem;
                margin-bottom: 34px
            }

        .form-field {
            margin-bottom: 18px
        }

            .form-field label {
                font-weight: 600;
                font-size: .83rem;
                color: #444;
                display: block;
                margin-bottom: 7px
            }

            .form-field input {
                width: 100%;
                padding: 12px 16px;
                border: 1.5px solid rgba(0,0,0,.1);
                border-radius: 10px;
                font-family: "DM Sans",sans-serif;
                font-size: .95rem;
                background: white;
                transition: border-color .2s,box-shadow .2s;
                outline: none
            }

                .form-field input:focus {
                    border-color: #5c3dde;
                    box-shadow: 0 0 0 3px rgba(92,61,222,.1)
                }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: #0a0a12;
            color: white;
            border: none;
            border-radius: 50px;
            font-family: "Syne",sans-serif;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: background .2s,transform .2s;
            margin-bottom: 18px
        }

            .btn-submit:hover {
                background: #5c3dde;
                transform: translateY(-1px)
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #ccc;
            font-size: .8rem;
            margin: 20px 0
        }

            .divider::before, .divider::after {
                content: "";
                flex: 1;
                height: 1px;
                background: #e0e0e0
            }

        .btn-google {
            width: 100%;
            padding: 12px 16px;
            background: white;
            color: #333;
            border: 1.5px solid rgba(0,0,0,.1);
            border-radius: 50px;
            font-weight: 600;
            font-size: .9rem;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            margin-bottom: 22px
        }

            .btn-google:hover {
                border-color: #5c3dde;
                color: #333
            }

        .auth-footer {
            text-align: center;
            font-size: .88rem;
            color: #888
        }

            .auth-footer a {
                color: #5c3dde;
                font-weight: 600;
                text-decoration: none
            }

                .auth-footer a:hover {
                    text-decoration: underline
                }

        .error-msg {
            background: #fde8ed;
            color: #c0392b;
            padding: 11px 15px;
            border-radius: 8px;
            font-size: .86rem;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px
        }

        @@media(max-width:768px) {
            body {
                grid-template-columns: 1fr
            }

            .left-panel {
                display: none
            }
        }
    </style>
</head>
<body>
    <!-- LEFT -->
    <div class="left-panel">
        <a href="/" class="brand">🚀 Habit<span>Tracker</span></a>

        <div class="hero-text">
            <h2>Gamify your<br>daily habits.</h2>
            <p>Hoàn thành quest, nhận XP, lên level — xây dựng thói quen tốt như chơi game.</p>
        </div>

        <div class="feature-list">
            <div class="feat-item"><div class="feat-dot">🎯</div><span>Hệ thống Quest & XP gamification</span></div>
            <div class="feat-item"><div class="feat-dot">🔥</div><span>Streak tracking — duy trì động lực</span></div>
            <div class="feat-item"><div class="feat-dot">🏆</div><span>Badges & Leaderboard cộng đồng</span></div>
            <div class="feat-item"><div class="feat-dot">📊</div><span>Dashboard thống kê chi tiết</span></div>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="right-panel">
        <div class="auth-box">
            <h3>Chào mừng trở lại 👋</h3>
            <p class="subtitle">Đăng nhập để tiếp tục hành trình của bạn</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-msg">❌ @ViewBag.Error</div>
            }

            <form method="post">
                <div class="form-field">
                    <label>Email</label>
                    <input asp-for="Email" placeholder="you@example.com" autocomplete="email" />
                </div>
                <div class="form-field">
                    <label>Mật khẩu</label>
                    <input asp-for="Password" type="password" placeholder="••••••••" />
                </div>
                <button type="submit" class="btn-submit">Đăng nhập →</button>
            </form>

            <div class="divider">hoặc</div>

            <a asp-controller="Account" asp-action="GoogleLogin" class="btn-google">
                <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" /><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" /><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" /><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" /></svg>
                Tiếp tục với Google
            </a>

            <div class="auth-footer">
                Chưa có tài khoản? <a href="/Account/Register">Đăng ký miễn phí</a>
            </div>
        </div>
    </div>
</body>
</html>
