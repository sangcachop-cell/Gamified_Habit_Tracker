@model List<HabitTracker.Models.Badge>
@{
    ViewData["Title"] = "Admin — Quản lý Badge";
    var active = Model.Where(b => b.IsActive).ToList();
    var inactive = Model.Where(b => !b.IsActive).ToList();
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --violet: #5c3dde;
        --gold: #f0b429;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4 {
        font-family: "Syne",sans-serif
    }

    .admin-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 28px 36px;
        color: white;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 14px
    }

        .admin-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 10% 60%,rgba(240,180,41,.3),transparent 50%),radial-gradient(ellipse at 90% 30%,rgba(92,61,222,.3),transparent 55%);
            pointer-events: none
        }

        .admin-hero h2 {
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -1px;
            position: relative;
            z-index: 2;
            margin: 0
        }

        .admin-hero p {
            color: rgba(255,255,255,.55);
            font-size: .85rem;
            margin: 4px 0 0;
            position: relative;
            z-index: 2
        }

    .btn-new {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--gold);
        color: var(--ink);
        padding: 11px 22px;
        border-radius: 50px;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s;
        position: relative;
        z-index: 2
    }

        .btn-new:hover {
            background: #d4a000;
            transform: translateY(-1px);
            color: var(--ink)
        }

    .glass-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        overflow: hidden;
        margin-bottom: 24px;
        box-shadow: 0 4px 16px rgba(0,0,0,.04)
    }

    .card-head {
        padding: 16px 22px;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: space-between
    }

        .card-head h4 {
            font-size: .9rem;
            font-weight: 700;
            margin: 0
        }

    .count-chip {
        background: var(--soft);
        color: var(--violet);
        padding: 3px 10px;
        border-radius: 50px;
        font-size: .73rem;
        font-weight: 700
    }

    table {
        width: 100%;
        border-collapse: collapse
    }

    th {
        padding: 11px 16px;
        text-align: left;
        font-size: .73rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #aaa;
        background: #fafafa;
        border-bottom: 1px solid #f0f0f0
    }

    td {
        padding: 13px 16px;
        border-bottom: 1px solid #f8f8f8;
        vertical-align: middle;
        font-size: .88rem
    }

    tr:last-child td {
        border: none
    }

    tr:hover td {
        background: #fafcff
    }

    .b-icon-cell {
        font-size: 1.6rem;
        text-align: center
    }

    .b-name {
        font-weight: 700;
        font-size: .9rem
    }

    .b-desc {
        font-size: .77rem;
        color: #aaa;
        margin-top: 2px
    }

    .rarity-pill {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 50px;
        font-size: .72rem;
        font-weight: 700;
        color: white
    }

    .rp-Common {
        background: #808080
    }

    .rp-Rare {
        background: #0070DD
    }

    .rp-Epic {
        background: #A335EE
    }

    .rp-Legendary {
        background: #FF8000
    }

    .xp-val {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        color: var(--violet)
    }

    .btn-edit {
        padding: 6px 14px;
        background: var(--soft);
        color: var(--violet);
        border: none;
        border-radius: 50px;
        font-size: .78rem;
        font-weight: 600;
        text-decoration: none;
        transition: background .2s;
        display: inline-flex;
        align-items: center;
        gap: 4px
    }

        .btn-edit:hover {
            background: #ddd8f5;
            color: var(--violet)
        }

    .btn-del {
        padding: 6px 14px;
        background: #fde8ed;
        color: var(--rose);
        border: none;
        border-radius: 50px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer
    }

    .btn-restore {
        padding: 6px 14px;
        background: #d4f5ef;
        color: var(--teal);
        border: none;
        border-radius: 50px;
        font-size: .78rem;
        font-weight: 600;
        cursor: pointer
    }

    .alert-s {
        background: #d4f5ef;
        color: #006651;
        padding: 11px 16px;
        border-radius: 10px;
        font-size: .88rem;
        margin-bottom: 18px
    }

    .nav-tabs-custom {
        display: flex;
        gap: 8px;
        margin-bottom: 20px
    }

    .nav-tab {
        padding: 9px 20px;
        border-radius: 50px;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .85rem;
        text-decoration: none;
        background: white;
        color: #888;
        border: 1.5px solid rgba(0,0,0,.07);
        transition: all .2s
    }

        .nav-tab:hover, .nav-tab.active {
            background: var(--ink);
            color: white;
            border-color: var(--ink)
        }
</style>

<div style="padding:8px 0 48px">

    @if (TempData["Success"] != null)
    {
        <div class="alert-s">✅ @TempData["Success"]</div>
    }

    <div class="admin-hero">
        <div>
            <h2>🏆 Quản lý Badge</h2>
            <p>Tạo và quản lý huy hiệu phần thưởng</p>
        </div>
        <div style="display:flex;gap:10px;position:relative;z-index:2;flex-wrap:wrap">
            <a asp-action="Index" class="nav-tab">⚙️ Quests</a>
            <a asp-action="Badges" class="nav-tab active">🏆 Badges</a>
            <a asp-action="CreateBadge" class="btn-new">+ Thêm Badge</a>
        </div>
    </div>

    <div class="glass-card">
        <div class="card-head">
            <h4>✅ Badge đang hoạt động</h4>
            <span class="count-chip">@active.Count</span>
        </div>
        <table>
            <thead>
                <tr><th>Icon</th><th>Tên Badge</th><th>Rarity</th><th>XP yêu cầu</th><th>Đã trao</th><th>Hành động</th></tr>
            </thead>
            <tbody>
                @foreach (var b in active)
                {
                    <tr>
                        <td class="b-icon-cell">@b.Icon</td>
                        <td>
                            <div class="b-name">@b.Name</div>
                            @if (!string.IsNullOrEmpty(b.Description))
                            {
                                <div class="b-desc">@b.Description</div>
                            }
                        </td>
                        <td><span class="rarity-pill rp-@b.Rarity">@b.Rarity</span></td>
                        <td><span class="xp-val">@b.RequiredXP XP</span></td>
                        <td style="color:#aaa;font-size:.82rem">@(b.UserBadges?.Count ?? 0) người</td>
                        <td>
                            <a asp-action="EditBadge" asp-route-id="@b.Id" class="btn-edit">✏️ Sửa</a>
                            <form asp-action="DeleteBadge" method="post" style="display:inline"
                                  onsubmit="return confirm('Ẩn badge «@b.Name»?')">
                                <input type="hidden" name="id" value="@b.Id" />
                                <button class="btn-del">🗑️ Ẩn</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (inactive.Any())
    {
        <div class="glass-card">
            <div class="card-head">
                <h4 style="color:#aaa">🚫 Badge đã ẩn</h4>
                <span class="count-chip" style="background:#f0f0f0;color:#888">@inactive.Count</span>
            </div>
            <table>
                <thead><tr><th>Icon</th><th>Tên</th><th>Rarity</th><th>Hành động</th></tr></thead>
                <tbody>
                    @foreach (var b in inactive)
                    {
                        <tr style="opacity:.6">
                            <td class="b-icon-cell">@b.Icon</td>
                            <td><div class="b-name" style="text-decoration:line-through">@b.Name</div></td>
                            <td><span class="rarity-pill rp-@b.Rarity">@b.Rarity</span></td>
                            <td>
                                <form asp-action="DeleteBadge" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@b.Id" />
                                    <button class="btn-restore" formaction="/Admin/RestoreBadge">♻️ Khôi phục</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
