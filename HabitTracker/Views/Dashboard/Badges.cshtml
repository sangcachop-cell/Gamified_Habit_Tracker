@model List<HabitTracker.Models.UserBadge>
@{
    ViewData["Title"] = "Badges của tôi";
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --violet: #5c3dde;
        --gold: #f0b429;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4 {
        font-family: "Syne",sans-serif
    }

    .page-back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #888;
        text-decoration: none;
        font-size: .85rem;
        margin-bottom: 20px;
        transition: color .2s
    }

        .page-back:hover {
            color: var(--violet)
        }

    .badges-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 30px 36px;
        color: white;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px
    }

        .badges-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 60%,rgba(92,61,222,.45),transparent 55%),radial-gradient(ellipse at 80% 30%,rgba(240,180,41,.2),transparent 55%);
            pointer-events: none
        }

        .badges-hero h2 {
            font-size: 1.7rem;
            font-weight: 800;
            letter-spacing: -1px;
            position: relative;
            z-index: 2;
            margin: 0
        }

        .badges-hero p {
            color: rgba(255,255,255,.55);
            font-size: .88rem;
            margin: 4px 0 0;
            position: relative;
            z-index: 2
        }

    .stats-bar {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 24px
    }

    .stat-chip {
        background: white;
        border-radius: 12px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 14px 20px;
        text-align: center;
        flex: 1;
        min-width: 110px
    }

        .stat-chip .n {
            font-family: "Syne",sans-serif;
            font-weight: 800;
            font-size: 1.6rem;
            line-height: 1
        }

        .stat-chip .l {
            font-size: .73rem;
            color: #aaa;
            margin-top: 4px
        }

    .n-common {
        color: #808080
    }

    .n-rare {
        color: #0070DD
    }

    .n-epic {
        color: #A335EE
    }

    .n-legendary {
        color: #FF8000
    }

    .n-total {
        color: var(--violet)
    }

    .badges-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(230px,1fr));
        gap: 16px
    }

    .badge-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 22px 20px;
        text-align: center;
        transition: all .25s;
        position: relative;
        overflow: hidden
    }

        .badge-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 32px rgba(0,0,0,.1)
        }

        .badge-card.new-card {
            border-color: var(--gold)
        }

    .new-ribbon {
        position: absolute;
        top: 10px;
        right: -22px;
        background: var(--gold);
        color: #333;
        font-size: .65rem;
        font-weight: 800;
        padding: 3px 32px;
        transform: rotate(35deg);
        letter-spacing: .5px
    }

    .b-icon {
        font-size: 3rem;
        margin-bottom: 10px;
        display: block
    }

    .b-name {
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 6px
    }

    .b-desc {
        font-size: .82rem;
        color: #888;
        line-height: 1.5;
        margin-bottom: 12px
    }

    .b-meta {
        display: flex;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap
    }

    .rarity-pill {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: .73rem;
        font-weight: 700;
        color: white
    }

    .rp-Common {
        background: #808080
    }

    .rp-Rare {
        background: #0070DD
    }

    .rp-Epic {
        background: #A335EE
    }

    .rp-Legendary {
        background: #FF8000
    }

    .xp-pill {
        background: var(--soft);
        color: var(--violet);
        padding: 4px 12px;
        border-radius: 50px;
        font-size: .73rem;
        font-weight: 700
    }

    .b-date {
        font-size: .72rem;
        color: #ccc;
        margin-top: 10px
    }

    .empty-state {
        text-align: center;
        padding: 64px 24px;
        background: white;
        border-radius: 20px
    }

    .empty-emoji {
        font-size: 4rem;
        display: block;
        margin-bottom: 14px
    }

    @@media(max-width:600px) {
        .badges-grid {
            grid-template-columns: 1fr 1fr
        }
    }
</style>

<div style="padding:8px 0 48px">
    <a href="javascript:history.back()" class="page-back">← Quay lại</a>

    <div class="badges-hero">
        <div>
            <h2>🏆 Badges của tôi</h2>
            <p>Bộ sưu tập huy hiệu — thể hiện thành tích của bạn</p>
        </div>
        <div style="position:relative;z-index:2;font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:rgba(255,255,255,.15)">
            @(Model?.Count ?? 0) badges
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        var byRarity = Model.GroupBy(b => b.Badge?.Rarity ?? "Common").ToDictionary(g => g.Key, g => g.Count());
        int lgCount = byRarity.TryGetValue("Legendary", out int lg) ? lg : 0;
        int epCount = byRarity.TryGetValue("Epic", out int ep) ? ep : 0;
        int rrCount = byRarity.TryGetValue("Rare", out int rr) ? rr : 0;
        int cmCount = byRarity.TryGetValue("Common", out int cm) ? cm : 0;

        <div class="stats-bar">
            <div class="stat-chip"><div class="n n-total">@Model.Count</div><div class="l">Tổng</div></div>
            @if (lgCount > 0)
            {
                <div class="stat-chip"><div class="n n-legendary">@lgCount</div><div class="l">Legendary</div></div>
            }
            @if (epCount > 0)
            {
                <div class="stat-chip"><div class="n n-epic">@epCount</div><div class="l">Epic</div></div>
            }
            @if (rrCount > 0)
            {
                <div class="stat-chip"><div class="n n-rare">@rrCount</div><div class="l">Rare</div></div>
            }
            @if (cmCount > 0)
            {
                <div class="stat-chip"><div class="n n-common">@cmCount</div><div class="l">Common</div></div>
            }
        </div>

        <div class="badges-grid">
            @foreach (var ub in Model.OrderByDescending(b => b.EarnedDate))
            {
                var isNew = ub.IsNewlyEarned();
                var rarity = ub.Badge?.Rarity ?? "Common";
                <div class="badge-card @(isNew ? "new-card" : "")">
                    @if (isNew)
                    {
                        <div class="new-ribbon">NEW</div>
                    }
                    <span class="b-icon">@(ub.Badge?.Icon ?? "🏅")</span>
                    <div class="b-name">@(ub.Badge?.Name ?? "Badge")</div>
                    @if (!string.IsNullOrEmpty(ub.Badge?.Description))
                    {
                        <div class="b-desc">@ub.Badge.Description</div>
                    }
                    <div class="b-meta">
                        <span class="rarity-pill rp-@rarity">@rarity</span>
                        @if (ub.Badge != null && ub.Badge.RequiredXP > 0)
                        {
                            <span class="xp-pill">@ub.Badge.RequiredXP XP</span>
                        }
                    </div>
                    <div class="b-date">🗓️ @ub.EarnedDate.ToString("dd/MM/yyyy")</div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <span class="empty-emoji">🏅</span>
            <h4 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:8px">Chưa có badge nào</h4>
            <p style="color:#aaa;font-size:.9rem;margin-bottom:24px">Hoàn thành quest để nhận badge đầu tiên!</p>
            <a href="/Task" style="display:inline-flex;align-items:center;gap:6px;background:var(--ink);color:white;padding:12px 28px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;text-decoration:none">📋 Đi làm quest ngay</a>
        </div>
    }
</div>
