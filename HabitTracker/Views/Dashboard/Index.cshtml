@model HabitTracker.Models.User
@{
    ViewData["Title"] = "Dashboard";
    int xpInLevel = Model.XP % 100;
    var best = Model.UserQuests?.OrderByDescending(uq => uq.Quest?.XPReward).FirstOrDefault();
    var recentBadges = Model.UserBadges?.OrderByDescending(b => b.EarnedDate).Take(3).ToList();
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --gold: #f0b429;
        --violet: #5c3dde;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4, h5 {
        font-family: "Syne",sans-serif
    }

    .dash-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 32px 36px;
        color: white;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px
    }

        .dash-hero::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(92,61,222,.35) 0%,transparent 70%);
            top: -150px;
            right: -100px;
            pointer-events: none
        }

        .dash-hero::after {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(240,180,41,.2) 0%,transparent 70%);
            bottom: -100px;
            left: 200px;
            pointer-events: none
        }

    .hero-left {
        position: relative;
        z-index: 2
    }

    .hero-greeting {
        font-size: .82rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: rgba(255,255,255,.5);
        margin-bottom: 8px
    }

    .hero-left h2 {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 16px
    }

    .level-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 50px;
        padding: 8px 18px;
        margin-bottom: 20px
    }

        .level-badge .lv {
            font-family: "Syne",sans-serif;
            font-weight: 800;
            font-size: 1rem
        }

    .xp-bar-wrap {
        width: 280px
    }

    .xp-bar-label {
        display: flex;
        justify-content: space-between;
        font-size: .78rem;
        color: rgba(255,255,255,.6);
        margin-bottom: 6px
    }

    .xp-bar {
        height: 8px;
        background: rgba(255,255,255,.12);
        border-radius: 50px;
        overflow: hidden
    }

    .xp-fill {
        height: 100%;
        background: linear-gradient(90deg,var(--gold),var(--rose));
        border-radius: 50px;
        transition: width 1s ease
    }

    .hero-stats {
        display: flex;
        gap: 28px;
        position: relative;
        z-index: 2;
        flex-wrap: wrap
    }

    .hstat {
        text-align: center
    }

        .hstat .num {
            font-family: "Syne",sans-serif;
            font-size: 2rem;
            font-weight: 800
        }

        .hstat .lbl {
            font-size: .75rem;
            color: rgba(255,255,255,.5);
            margin-top: 2px
        }
    /* grid */
    .dash-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
        margin-bottom: 28px
    }

    .glass-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        box-shadow: 0 4px 24px rgba(0,0,0,.05);
        padding: 24px
    }

    .card-eyebrow {
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #aaa;
        margin-bottom: 8px
    }

    .card-big {
        font-family: "Syne",sans-serif;
        font-size: 2.4rem;
        font-weight: 800;
        letter-spacing: -1px;
        line-height: 1
    }

    .card-sub {
        font-size: .82rem;
        color: #888;
        margin-top: 6px
    }

    .card-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        margin-bottom: 14px
    }
    /* chart */
    .chart-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        box-shadow: 0 4px 24px rgba(0,0,0,.05);
        padding: 24px;
        margin-bottom: 28px
    }

        .chart-card h4 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 20px;
            letter-spacing: -.3px
        }
    /* quest row */
    .quest-mini {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0
    }

        .quest-mini:last-child {
            border: none
        }

    .q-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0
    }

    .q-name {
        font-weight: 600;
        font-size: .88rem;
        flex: 1
    }

    .q-xp {
        font-family: "Syne",sans-serif;
        font-weight: 700;
        color: var(--violet);
        font-size: .85rem
    }
    /* badge */
    .badge-mini {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid #f0f0f0
    }

        .badge-mini:last-child {
            border: none
        }

    .b-icon {
        font-size: 1.6rem
    }

    .b-name {
        font-weight: 600;
        font-size: .88rem
    }

    .b-date {
        font-size: .75rem;
        color: #aaa
    }

    @@media(max-width:900px) {
        .dash-grid {
            grid-template-columns: 1fr 1fr
        }

        .hero-stats {
            gap: 16px
        }
    }

    @@media(max-width:600px) {
        .dash-grid {
            grid-template-columns: 1fr
        }

        .dash-hero {
            padding: 24px
        }
    }
</style>

<div style="padding:8px 0 32px">

    <!-- Hero Banner -->
    <div class="dash-hero">
        <div class="hero-left">
            <div class="hero-greeting">Welcome back</div>
            <h2>@Model.Username 👋</h2>
            <div class="level-badge">
                <span>⚡</span>
                <span class="lv">Level @Model.Level</span>
                <span style="color:rgba(255,255,255,.4);font-size:.82rem">· @Model.XP XP tổng cộng</span>
            </div>
            <div class="xp-bar-wrap">
                <div class="xp-bar-label"><span>@xpInLevel / 100 XP</span><span>→ Level @(Model.Level + 1)</span></div>
                <div class="xp-bar"><div class="xp-fill" style="width:@xpInLevel%"></div></div>
            </div>
        </div>
        <div class="hero-stats">
            <div class="hstat"><div class="num">@Model.CurrentStreak 🔥</div><div class="lbl">Streak hiện tại</div></div>
            <div class="hstat"><div class="num">@(Model.UserQuests?.Count ?? 0)</div><div class="lbl">Quests đã làm</div></div>
            <div class="hstat"><div class="num">@(Model.UserBadges?.Count ?? 0)</div><div class="lbl">Badges</div></div>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="dash-grid">
        <div class="glass-card">
            <div class="card-icon" style="background:#ede9ff">⚡</div>
            <div class="card-eyebrow">Tổng XP</div>
            <div class="card-big" style="color:var(--violet)">@Model.XP.ToString("N0")</div>
            <div class="card-sub">@Model.TotalXPEarned.ToString("N0") XP lifetime</div>
        </div>
        <div class="glass-card">
            <div class="card-icon" style="background:#fde8ed">🔥</div>
            <div class="card-eyebrow">Streak dài nhất</div>
            <div class="card-big" style="color:var(--rose)">@Model.LongestStreak</div>
            <div class="card-sub">Hiện tại: @Model.CurrentStreak ngày</div>
        </div>
        <div class="glass-card">
            <div class="card-icon" style="background:#e2f5e2">✅</div>
            <div class="card-eyebrow">Hoàn thành</div>
            <div class="card-big" style="color:var(--teal)">@Model.TotalQuestsCompleted</div>
            <div class="card-sub">Tổng số quest</div>
        </div>
    </div>

    <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:28px">
        <!-- Chart -->
        <div class="chart-card">
            <h4>📈 Quests hoàn thành — 7 ngày qua</h4>
            <canvas id="habitChart" height="90"></canvas>
        </div>

        <!-- Best Quest -->
        <div class="glass-card">
            <div class="card-eyebrow">Quest tốt nhất</div>
            @if (best?.Quest != null)
            {
                <div style="margin-top:12px">
                    <div style="font-size:2rem;margin-bottom:8px">@best.Quest.Icon</div>
                    <div style="font-weight:700;font-size:.95rem;margin-bottom:8px">@best.Quest.Name</div>
                    <span style="background:#ede9ff;color:var(--violet);padding:4px 12px;border-radius:20px;font-size:.78rem;font-weight:700">+@best.Quest.XPReward XP</span>
                    <span style="background:#f0f0f0;color:#555;padding:4px 12px;border-radius:20px;font-size:.78rem;margin-left:6px">@best.Quest.Category</span>
                </div>
            }
            else
            {
                <div style="color:#aaa;font-size:.88rem;margin-top:12px">Chưa hoàn thành quest nào. Bắt đầu ngay! 🚀</div>
            }

            <div style="margin-top:20px;padding-top:16px;border-top:1px solid #f0f0f0">
                <a href="/Task" style="display:inline-flex;align-items:center;gap:6px;background:var(--ink);color:white;padding:9px 18px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:.82rem;text-decoration:none">
                    📋 Làm quest ngay
                </a>
            </div>
        </div>
    </div>

    <!-- Badges & Quick links -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
        <div class="glass-card">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
                <div class="card-eyebrow" style="margin:0">🏆 Badges gần đây</div>
                <a href="/Dashboard/Badges" style="font-size:.8rem;color:var(--violet);text-decoration:none;font-weight:600">Xem tất cả →</a>
            </div>
            @if (recentBadges != null && recentBadges.Count > 0)
            {
                foreach (var ub in recentBadges)
                {
                    <div class="badge-mini">
                        <div class="b-icon">@(ub.Badge?.Icon ?? "🏅")</div>
                        <div><div class="b-name">@(ub.Badge?.Name ?? "Badge")</div><div class="b-date">@ub.EarnedDate.ToString("dd/MM/yyyy")</div></div>
                    </div>
                }
            }
            else
            {
                <div style="color:#aaa;font-size:.88rem">Chưa có badge nào. Hoàn thành quest để nhận badge!</div>
            }
        </div>

        <div class="glass-card">
            <div class="card-eyebrow" style="margin-bottom:16px">⚡ Hành động nhanh</div>
            <div style="display:flex;flex-direction:column;gap:10px">
                <a href="/Task" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;background:var(--soft);text-decoration:none;color:var(--ink);font-weight:600;font-size:.9rem;transition:background .2s" onmouseover="this.style.background='#ddd8f5'" onmouseout="this.style.background='var(--soft)'">📋 <span>Danh sách Quest</span></a>
                <a href="/Task/search" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;background:var(--soft);text-decoration:none;color:var(--ink);font-weight:600;font-size:.9rem;transition:background .2s" onmouseover="this.style.background='#ddd8f5'" onmouseout="this.style.background='var(--soft)'">🔍 <span>Tìm kiếm Quest</span></a>
                <a href="/Dashboard/Statistics" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;background:var(--soft);text-decoration:none;color:var(--ink);font-weight:600;font-size:.9rem;transition:background .2s" onmouseover="this.style.background='#ddd8f5'" onmouseout="this.style.background='var(--soft)'">📊 <span>Thống kê chi tiết</span></a>
                <a href="/Account/Leaderboard" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;background:var(--soft);text-decoration:none;color:var(--ink);font-weight:600;font-size:.9rem;transition:background .2s" onmouseover="this.style.background='#ddd8f5'" onmouseout="this.style.background='var(--soft)'">🏅 <span>Bảng xếp hạng</span></a>
                <a href="/Account/Profile" style="display:flex;align-items:center;gap:10px;padding:12px 16px;border-radius:12px;background:var(--soft);text-decoration:none;color:var(--ink);font-weight:600;font-size:.9rem;transition:background .2s" onmouseover="this.style.background='#ddd8f5'" onmouseout="this.style.background='var(--soft)'">👤 <span>Hồ sơ cá nhân</span></a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('habitChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.ChartLabels)],
                datasets: [{
                    label: 'Quests hoàn thành',
                    data: [@Html.Raw(ViewBag.ChartData)],
                    borderColor: '#5c3dde',
                    backgroundColor: 'rgba(92,61,222,.08)',
                    borderWidth: 2.5, tension: 0.4, fill: true,
                    pointBackgroundColor: '#5c3dde', pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,.05)' } }, x: { grid: { display: false } } }
            }
        });
    </script>
}
