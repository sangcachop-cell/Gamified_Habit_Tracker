@using HabitTracker.Models.ViewModels
@model StatisticsViewModel
@{
    ViewData["Title"] = "Thống kê";
    var dayNames = new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --violet: #5c3dde;
        --gold: #f0b429;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4 {
        font-family: "Syne",sans-serif
    }

    .stat-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 32px 36px;
        color: white;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden
    }

        .stat-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%,rgba(92,61,222,.5),transparent 55%),radial-gradient(ellipse at 80% 50%,rgba(240,180,41,.25),transparent 55%);
            pointer-events: none
        }

        .stat-hero h2 {
            font-size: 1.9rem;
            font-weight: 800;
            letter-spacing: -1px;
            position: relative;
            z-index: 2;
            margin-bottom: 6px
        }

        .stat-hero p {
            color: rgba(255,255,255,.6);
            position: relative;
            z-index: 2;
            font-size: .9rem
        }
    /* kpi cards */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 16px;
        margin-bottom: 24px
    }

    .kpi {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 22px;
        position: relative;
        overflow: hidden
    }

        .kpi::before {
            content: "";
            position: absolute;
            top: -20px;
            right: -20px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            opacity: .08
        }

    .kpi-violet::before {
        background: var(--violet)
    }

    .kpi-gold::before {
        background: var(--gold)
    }

    .kpi-teal::before {
        background: var(--teal)
    }

    .kpi-rose::before {
        background: var(--rose)
    }

    .kpi-icon {
        font-size: 1.5rem;
        margin-bottom: 10px
    }

    .kpi-label {
        font-size: .73rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #aaa;
        margin-bottom: 6px
    }

    .kpi-val {
        font-family: "Syne",sans-serif;
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -1px;
        line-height: 1
    }

    .kpi-sub {
        font-size: .8rem;
        color: #aaa;
        margin-top: 6px
    }

    .kpi-violet .kpi-val {
        color: var(--violet)
    }

    .kpi-gold .kpi-val {
        color: #b07800
    }

    .kpi-teal .kpi-val {
        color: var(--teal)
    }

    .kpi-rose .kpi-val {
        color: var(--rose)
    }
    /* comparison */
    .compare-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 22px;
        margin-bottom: 24px
    }

        .compare-card h4 {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 16px;
            letter-spacing: -.3px
        }

    .compare-bars {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px
    }

    .cbar-wrap {
        background: #f8f8f8;
        border-radius: 12px;
        padding: 16px
    }

    .cbar-label {
        font-size: .78rem;
        font-weight: 600;
        color: #888;
        margin-bottom: 8px
    }

    .cbar-num {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        font-size: 1.5rem;
        margin-bottom: 8px
    }

    .cbar {
        height: 8px;
        background: #e8e8e8;
        border-radius: 50px;
        overflow: hidden
    }

    .cbar-fill {
        height: 100%;
        border-radius: 50px;
        transition: width 1s ease
    }

    .alert-above {
        background: #d4f5ef;
        color: #006651;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: .88rem;
        font-weight: 600;
        margin-top: 12px
    }

    .alert-below {
        background: #fff5d6;
        color: #7a5200;
        padding: 12px 16px;
        border-radius: 10px;
        font-size: .88rem;
        font-weight: 600;
        margin-top: 12px
    }
    /* charts */
    .chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px
    }

    .chart-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 24px
    }

        .chart-card h4 {
            font-size: .95rem;
            font-weight: 700;
            margin-bottom: 18px;
            letter-spacing: -.3px
        }

    .chart-wrap {
        position: relative;
        height: 260px
    }
    /* achievements */
    .ach-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(180px,1fr));
        gap: 14px
    }

    .ach-item {
        background: white;
        border-radius: 14px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 18px;
        text-align: center;
        transition: all .25s
    }

        .ach-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,.08)
        }

    .ach-icon {
        font-size: 2rem;
        margin-bottom: 8px
    }

    .ach-name {
        font-weight: 700;
        font-size: .85rem;
        margin-bottom: 4px
    }

    .ach-date {
        font-size: .75rem;
        color: #aaa
    }
    /* summary */
    .summary-card {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 24px;
        margin-bottom: 24px
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 0
    }

    .sum-item {
        padding: 12px 16px;
        border-right: 1px solid #f0f0f0;
        text-align: center
    }

        .sum-item:last-child {
            border: none
        }

    .sum-num {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        font-size: 1.5rem;
        color: var(--violet)
    }

    .sum-lbl {
        font-size: .78rem;
        color: #aaa;
        margin-top: 4px
    }

    @@media(max-width:900px) {
        .kpi-grid {
            grid-template-columns: 1fr 1fr
        }

        .chart-grid {
            grid-template-columns: 1fr
        }

        .summary-grid {
            grid-template-columns: 1fr 1fr
        }
    }

    @@media(max-width:600px) {
        .kpi-grid {
            grid-template-columns: 1fr
        }

        .compare-bars {
            grid-template-columns: 1fr
        }

        .summary-grid {
            grid-template-columns: 1fr 1fr
        }
    }
</style>

<div style="padding:8px 0 48px">

    <div class="stat-hero">
        <h2>📊 Thống kê chi tiết</h2>
        <p>Theo dõi tiến trình và hiệu suất của bạn trong 30 ngày qua</p>
    </div>

    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi kpi-violet">
            <div class="kpi-icon">✅</div>
            <div class="kpi-label">Hôm nay</div>
            <div class="kpi-val">@Model.QuestStats.Completed<span style="font-size:1.2rem;color:#aaa"> / @Model.QuestStats.Total</span></div>
            <div class="kpi-sub">@Model.QuestStats.Pending quest còn lại</div>
        </div>
        <div class="kpi kpi-teal">
            <div class="kpi-icon">📈</div>
            <div class="kpi-label">Completion Rate</div>
            <div class="kpi-val">@Model.PerformanceMetrics.CompletionRate.ToString("F0")%</div>
            <div class="kpi-sub">@Model.GetPerformanceRating()</div>
        </div>
        <div class="kpi kpi-gold">
            <div class="kpi-icon">⚡</div>
            <div class="kpi-label">XP / Ngày</div>
            <div class="kpi-val">@Model.PerformanceMetrics.AverageXPPerDay.ToString("F0")</div>
            <div class="kpi-sub">Trung bình 30 ngày</div>
        </div>
        <div class="kpi kpi-rose">
            <div class="kpi-icon">🎯</div>
            <div class="kpi-label">Consistency</div>
            <div class="kpi-val">@Model.PerformanceMetrics.ConsistencyScore%</div>
            <div class="kpi-sub">@Model.GetConsistencyStatus()</div>
        </div>
    </div>

    <!-- Summary strip -->
    <div class="summary-card" style="margin-bottom:24px">
        <div class="summary-grid">
            <div class="sum-item"><div class="sum-num">@Model.GetTotalCompletions()</div><div class="sum-lbl">Tổng completions</div></div>
            <div class="sum-item"><div class="sum-num">@Model.GetTotalXP()</div><div class="sum-lbl">Tổng XP (30 ngày)</div></div>
            <div class="sum-item"><div class="sum-num">@Model.GetTopCategory()</div><div class="sum-lbl">Category hàng đầu</div></div>
            <div class="sum-item"><div class="sum-num">@Model.Comparison.UserCompletion</div><div class="sum-lbl">Quest (7 ngày)</div></div>
        </div>
    </div>

    <!-- Comparison -->
    <div class="compare-card">
        <h4>📈 So sánh với cộng đồng (7 ngày)</h4>
        <div class="compare-bars">
            @{
                int maxVal = Math.Max(Model.Comparison.UserCompletion, Model.Comparison.AverageCompletion);
                int pctUser = maxVal > 0 ? Model.Comparison.UserCompletion * 100 / maxVal : 0;
                int pctAvg = maxVal > 0 ? Model.Comparison.AverageCompletion * 100 / maxVal : 0;
            }
            <div class="cbar-wrap">
                <div class="cbar-label">Bạn</div>
                <div class="cbar-num" style="color:var(--violet)">@Model.Comparison.UserCompletion quests</div>
                <div class="cbar"><div class="cbar-fill" style="width:@pctUser%;background:var(--violet)"></div></div>
            </div>
            <div class="cbar-wrap">
                <div class="cbar-label">Trung bình cộng đồng</div>
                <div class="cbar-num" style="color:#888">@Model.Comparison.AverageCompletion quests</div>
                <div class="cbar"><div class="cbar-fill" style="width:@pctAvg%;background:#ccc"></div></div>
            </div>
        </div>
        @if (Model.IsAboveAverage())
        {
            <div class="alert-above">✅ Bạn hoàn thành nhiều hơn mức trung bình cộng đồng! Xuất sắc!</div>
        }
        else
        {
            <div class="alert-below">💪 Cố thêm một chút nữa để vượt qua mức trung bình!</div>
        }
    </div>

    <!-- Charts -->
    <div class="chart-grid">
        <div class="chart-card">
            <h4>📈 Trend XP — 30 ngày</h4>
            <div class="chart-wrap"><canvas id="xpChart"></canvas></div>
        </div>
        <div class="chart-card">
            <h4>🏆 Breakdown theo Category</h4>
            <div class="chart-wrap"><canvas id="catChart"></canvas></div>
        </div>
        <div class="chart-card">
            <h4>🔥 Hoạt động theo ngày trong tuần</h4>
            <div class="chart-wrap"><canvas id="actChart"></canvas></div>
        </div>
        <div class="chart-card">
            <h4>⚔️ Breakdown theo Difficulty</h4>
            <div class="chart-wrap"><canvas id="diffChart"></canvas></div>
        </div>
    </div>

    <!-- Achievements -->
    @if (Model.RecentAchievements?.Any() == true)
    {
        <div class="chart-card" style="margin-bottom:0">
            <h4>🎖️ Achievements gần đây</h4>
            <div class="ach-grid" style="margin-top:16px">
                @foreach (var a in Model.RecentAchievements)
                {
                    <div class="ach-item">
                        <div class="ach-icon">🏅</div>
                        <div class="ach-name">@a.AchievementName</div>
                        <div class="ach-date">@a.AchievedDate.ToString("dd/MM/yyyy")</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    <script>
        Chart.defaults.font.family = "'DM Sans', sans-serif";
        Chart.defaults.color = '#888';
        const palette = ['#5c3dde','#f0b429','#e8436a','#00b89c','#9966ff','#ff9f40'];

        // XP Trend
        const xpData = @Html.Raw(Json.Serialize(Model.XPTrend));
        new Chart(document.getElementById('xpChart'), {
            type: 'line',
            data: {
                labels: xpData.map(x => new Date(x.date).toLocaleDateString('vi-VN')),
                datasets: [{ label: 'XP', data: xpData.map(x => x.xp), borderColor: '#5c3dde', backgroundColor: 'rgba(92,61,222,.08)', borderWidth: 2.5, tension: 0.4, fill: true, pointRadius: 3, pointBackgroundColor: '#5c3dde' }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,.05)' } }, x: { grid: { display: false }, ticks: { maxTicksLimit: 8 } } } }
        });

        // Category
        const catData = @Html.Raw(Json.Serialize(Model.CategoryBreakdown));
        new Chart(document.getElementById('catChart'), {
            type: 'doughnut',
            data: { labels: catData.map(x => x.category), datasets: [{ data: catData.map(x => x.count), backgroundColor: palette, borderWidth: 0 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 16, usePointStyle: true } } }, cutout: '65%' }
        });

        // Activity
        const actData = @Html.Raw(Json.Serialize(Model.ActivityByDay));
        const dayN = ['CN','T2','T3','T4','T5','T6','T7'];
        new Chart(document.getElementById('actChart'), {
            type: 'bar',
            data: { labels: actData.map(x => dayN[x.dayOfWeek]), datasets: [{ label: 'Quests', data: actData.map(x => x.count), backgroundColor: 'rgba(92,61,222,.15)', borderColor: '#5c3dde', borderWidth: 2, borderRadius: 8 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,.05)' } }, x: { grid: { display: false } } } }
        });

        // Difficulty
        const diffData = @Html.Raw(Json.Serialize(Model.DifficultyBreakdown));
        new Chart(document.getElementById('diffChart'), {
            type: 'bar',
            data: { labels: diffData.map(x => x.difficulty), datasets: [{ data: diffData.map(x => x.count), backgroundColor: ['rgba(0,184,156,.15)','rgba(240,180,41,.2)','rgba(232,67,106,.15)'], borderColor: ['#00b89c','#f0b429','#e8436a'], borderWidth: 2, borderRadius: 8 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,.05)' } }, x: { grid: { display: false } } } }
        });
    </script>
}
