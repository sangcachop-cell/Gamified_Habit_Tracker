@model HabitTracker.Models.BattleState
@{
    ViewData["Title"] = "Battle — " + Model.MonsterName;
    bool inProgress = Model.Status == "InProgress";
    bool won        = Model.Status == "Victory";
    bool lost       = Model.Status == "Defeat";
    bool fled       = Model.Status == "Fled";

    double playerHpPct  = Model.PlayerMaxHP  > 0 ? (double)Model.PlayerCurrentHP  / Model.PlayerMaxHP  * 100 : 0;
    double monsterHpPct = Model.MonsterMaxHP > 0 ? (double)Model.MonsterCurrentHP / Model.MonsterMaxHP * 100 : 0;

    string hpColor(double pct) =>
        pct > 60 ? "#00b89c" : pct > 30 ? "#f0b429" : "#e8436a";

    bool   playerFaster = Model.PlayerSpeed >= Model.MonsterSpeed;
    bool   playerBonus  = Model.PlayerSpeed  >= (int)(Model.MonsterSpeed * 1.5);
    bool   monsterBonus = Model.MonsterSpeed >= (int)(Model.PlayerSpeed  * 1.5);
    string speedLabel   = playerFaster ? "You act first" : $"{Model.MonsterName} acts first";
    string speedColor   = playerFaster ? "#00b89c" : "#e8436a";
}

<style>
    body { background: #0d0d1a; color: white; font-family: "DM Sans", sans-serif; min-height: 100vh; }
    h1,h2,h3,h4 { font-family: "Syne", sans-serif; }

    /* ── LAYOUT ── */
    .arena-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 20px 16px 60px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* ── COMBATANT PANELS ── */
    .combatants {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 16px;
        align-items: center;
    }

    .combatant-panel {
        background: linear-gradient(145deg, #1a1a2e, #16213e);
        border: 1.5px solid rgba(255,255,255,.08);
        border-radius: 20px;
        padding: 22px 20px;
    }
    .combatant-panel.player-panel { border-color: rgba(92,61,222,.35); }
    .combatant-panel.monster-panel { border-color: rgba(232,67,106,.35); }

    .combatant-name {
        font-size: .8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        opacity: .5;
        margin-bottom: 6px;
    }
    .combatant-title {
        font-size: 1.1rem;
        font-weight: 800;
        margin: 0 0 14px;
    }

    .hp-bar-track {
        background: rgba(255,255,255,.08);
        border-radius: 50px;
        height: 10px;
        overflow: hidden;
        margin-bottom: 6px;
    }
    .hp-bar-fill {
        height: 100%;
        border-radius: 50px;
        transition: width .5s ease, background .4s;
    }
    .hp-label {
        display: flex;
        justify-content: space-between;
        font-size: .78rem;
        opacity: .6;
        margin-bottom: 14px;
    }

    .stat-row {
        display: flex;
        gap: 14px;
        font-size: .78rem;
    }
    .stat-chip {
        background: rgba(255,255,255,.06);
        border-radius: 8px;
        padding: 4px 10px;
        font-weight: 700;
    }

    /* VS badge */
    .vs-badge {
        font-family: "Syne", sans-serif;
        font-size: 1.4rem;
        font-weight: 900;
        color: #f0b429;
        text-align: center;
        text-shadow: 0 0 20px rgba(240,180,41,.6);
    }

    /* Monster sprite */
    .monster-sprite-arena {
        font-size: 3.5rem;
        display: block;
        text-align: center;
        margin-bottom: 10px;
        filter: drop-shadow(0 0 18px rgba(232,67,106,.5));
    }
    @@keyframes monsterShake {
        0%,100% { transform: translateX(0); }
        20%      { transform: translateX(-6px); }
        40%      { transform: translateX(6px); }
        60%      { transform: translateX(-4px); }
        80%      { transform: translateX(4px); }
    }
    .shake { animation: monsterShake .4s ease; }

    /* ── COMBAT LOG ── */
    .combat-log {
        background: rgba(0,0,0,.35);
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 16px;
        padding: 16px;
        max-height: 220px;
        overflow-y: auto;
        font-size: .82rem;
        line-height: 1.8;
        display: flex;
        flex-direction: column;
        gap: 0;
    }
    .log-entry { padding: 1px 0; }
    .log-entry.turn-header {
        font-weight: 700;
        color: rgba(255,255,255,.35);
        font-size: .72rem;
        letter-spacing: .08em;
        margin-top: 6px;
    }

    /* ── ACTION BUTTONS ── */
    .action-bar {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
    }
    .action-btn {
        flex: 1;
        min-width: 130px;
        padding: 16px 10px;
        border: none;
        border-radius: 16px;
        font-family: "Syne", sans-serif;
        font-size: 1rem;
        font-weight: 800;
        cursor: pointer;
        transition: opacity .15s, transform .15s;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }
    .action-btn:hover { opacity: .88; transform: translateY(-2px); }
    .action-btn:active { transform: scale(.97); }
    .action-btn small { font-size: .68rem; font-weight: 400; opacity: .7; font-family: "DM Sans", sans-serif; }

    .btn-attack  { background: linear-gradient(135deg, #e8436a, #c0392b); color: white; box-shadow: 0 4px 18px rgba(232,67,106,.35); }
    .btn-defend  { background: linear-gradient(135deg, #4a9edd, #2980b9); color: white; box-shadow: 0 4px 18px rgba(74,158,221,.3); }
    .btn-run     { background: rgba(255,255,255,.06); color: rgba(255,255,255,.7); border: 1px solid rgba(255,255,255,.1); }

    /* ── OUTCOME BANNER ── */
    .outcome-banner {
        border-radius: 20px;
        padding: 36px 28px;
        text-align: center;
    }
    .outcome-banner.victory { background: linear-gradient(135deg, #11998e22, #38ef7d22); border: 1.5px solid #38ef7d44; }
    .outcome-banner.defeat  { background: linear-gradient(135deg, #e8436a22, #c0392b22); border: 1.5px solid #e8436a44; }
    .outcome-banner.fled    { background: rgba(255,255,255,.04); border: 1.5px solid rgba(255,255,255,.1); }
    .outcome-title { font-size: 2rem; font-weight: 900; margin: 0 0 8px; }
    .outcome-sub   { opacity: .6; font-size: .9rem; margin: 0 0 20px; }

    .btn-outcome {
        display: inline-block;
        padding: 12px 28px;
        border-radius: 12px;
        border: none;
        font-family: "Syne", sans-serif;
        font-weight: 700;
        font-size: .9rem;
        cursor: pointer;
        margin: 4px;
        transition: opacity .2s;
    }
    .btn-outcome:hover { opacity: .85; }
    .btn-again   { background: #e8436a; color: white; }
    .btn-back    { background: rgba(255,255,255,.08); color: white; }

    /* Turn counter */
    .turn-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(240,180,41,.12);
        border: 1px solid rgba(240,180,41,.25);
        color: #f0b429;
        border-radius: 50px;
        padding: 4px 14px;
        font-size: .75rem;
        font-weight: 700;
        margin-bottom: 14px;
    }

    @@media(max-width:600px) {
        .combatants { grid-template-columns: 1fr; }
        .vs-badge { display: none; }
    }
</style>

<div class="arena-wrap">

    <!-- Turn badge -->
    <div style="text-align:center;">
        <span class="turn-badge">
            ⚔️ Turn @(Model.Turn - 1 > 0 ? Model.Turn - 1 : 1)
            @if (!inProgress) { <span style="margin-left:6px; color:white;">— Battle Over</span> }
        </span>
    </div>

    <!-- Combatant panels -->
    <div class="combatants">

        <!-- PLAYER -->
        <div class="combatant-panel player-panel">
            <div class="combatant-name">Your Character</div>
            <div class="combatant-title">@Model.PlayerName</div>

            <div class="hp-bar-track">
                <div class="hp-bar-fill"
                     style="width:@playerHpPct.ToString("F1")%; background:@hpColor(playerHpPct);"></div>
            </div>
            <div class="hp-label">
                <span>❤️ @Model.PlayerCurrentHP / @Model.PlayerMaxHP HP</span>
                <span>@playerHpPct.ToString("F0")%</span>
            </div>

            <div class="stat-row">
                <div class="stat-chip">⚔️ @Model.PlayerAttack ATK</div>
                <div class="stat-chip">🛡️ @Model.PlayerArmor ARM</div>
                <div class="stat-chip" style="@(playerFaster ? "color:#00b89c;" : "color:#e8436a;")">
                    ⚡ @Model.PlayerSpeed SPD
                </div>
            </div>
        </div>

        <!-- VS + speed indicator -->
        <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
            <div class="vs-badge">VS</div>
            <div style="font-size:.65rem; text-align:center; color:@speedColor; font-weight:700; white-space:nowrap;">
                @speedLabel
                @if (playerBonus)  { <br /><span style="color:#f0b429;">⚡⚡ Bonus strike!</span> }
                @if (monsterBonus) { <br /><span style="color:#e8436a;">⚡⚡ Enemy bonus!</span> }
            </div>
        </div>

        <!-- MONSTER -->
        <div class="combatant-panel monster-panel" id="monster-panel">
            <div class="combatant-name">Enemy</div>
            <span class="monster-sprite-arena" id="monster-sprite">@Model.MonsterIcon</span>
            <div class="combatant-title" style="text-align:center;">@Model.MonsterName</div>

            <div class="hp-bar-track">
                <div class="hp-bar-fill"
                     style="width:@monsterHpPct.ToString("F1")%; background:@hpColor(monsterHpPct);"></div>
            </div>
            <div class="hp-label">
                <span>❤️ @Model.MonsterCurrentHP / @Model.MonsterMaxHP HP</span>
                <span>@monsterHpPct.ToString("F0")%</span>
            </div>

            <div class="stat-row" style="justify-content:center;">
                <div class="stat-chip">⚔️ @Model.MonsterAttack ATK</div>
                <div class="stat-chip">🛡️ @Model.MonsterArmor ARM</div>
                <div class="stat-chip" style="@(!playerFaster ? "color:#00b89c;" : "color:#e8436a;")">
                    ⚡ @Model.MonsterSpeed SPD
                </div>
            </div>
        </div>
    </div>

    <!-- Outcome banner (shown when battle is over) -->
    @if (!inProgress)
    {
        string bannerClass = won ? "victory" : lost ? "defeat" : "fled";
        string emoji       = won ? "🏆" : lost ? "💀" : "🏃";
        string title       = won  ? "Victory!"
                           : lost ? "Defeated..."
                           :         "Retreated";
        string sub         = won  ? $"+{Model.XPReward} XP awarded"
                           : lost ? "You fought bravely. Train harder."
                           :         "You lived to fight another day.";

        <div class="outcome-banner @bannerClass">
            <div style="font-size:3rem; margin-bottom:12px;">@emoji</div>
            <div class="outcome-title">@title</div>
            <div class="outcome-sub">@sub</div>

            <form asp-action="Start" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="monsterId" value="test_unit" />
                <button type="submit" class="btn-outcome btn-again">⚔️ Fight Again</button>
            </form>

            <form asp-action="Reset" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-outcome btn-back">🏰 Return to Lobby</button>
            </form>
        </div>
    }

    <!-- Combat log -->
    <div class="combat-log" id="combat-log">
        @foreach (var entry in Model.Log)
        {
            bool isHeader = entry.StartsWith("──");
            <div class="log-entry @(isHeader ? "turn-header" : "")">@entry</div>
        }
    </div>

    <!-- Action buttons (only during battle) -->
    @if (inProgress)
    {
        <div class="action-bar">
            <form asp-action="Action" method="post" style="flex:1; display:contents;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="attack" />
                <button type="submit" class="action-btn btn-attack" id="btn-attack">
                    ⚔️ Attack
                    <small>
                        @Model.PlayerAttack raw · @(playerBonus ? "⚡ bonus strike!" : playerFaster ? "you go first" : "enemy goes first")
                    </small>
                </button>
            </form>

            <form asp-action="Action" method="post" style="flex:1; display:contents;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="defend" />
                <button type="submit" class="action-btn btn-defend" id="btn-defend">
                    🛡️ Defend
                    <small>Double armor this turn</small>
                </button>
            </form>

            <form asp-action="Action" method="post" style="flex:1; display:contents;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="run" />
                <button type="submit" class="action-btn btn-run" id="btn-run">
                    🏃 Run Away
                    <small>60% chance to escape</small>
                </button>
            </form>
        </div>
    }

</div>

@section Scripts {
<script>
    // Auto-scroll log to top (newest entries)
    var log = document.getElementById('combat-log');
    if (log) log.scrollTop = 0;

    // Shake monster panel when it takes damage (detect from log)
    var firstEntry = '@(Model.Log.FirstOrDefault()?.Replace("'", "\\'") ?? "")';
    var sprite = document.getElementById('monster-sprite');
    if (sprite && firstEntry.includes('damage')) {
        sprite.classList.add('shake');
        setTimeout(function(){ sprite.classList.remove('shake'); }, 500);
    }

    // Disable buttons after click to prevent double-submit
    document.querySelectorAll('.action-btn').forEach(function(btn) {
        btn.closest('form').addEventListener('submit', function() {
            document.querySelectorAll('.action-btn').forEach(function(b) {
                b.disabled = true;
                b.style.opacity = '0.5';
            });
        });
    });
</script>
}
