@{
    ViewData["Title"] = "Battle";
    var entries = ViewBag.LobbyEntries as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<style>
    body { background: #0d0d1a; color: white; font-family: "DM Sans", sans-serif; }
    h1,h2,h3,h4 { font-family: "Syne", sans-serif; }

    .lobby-hero { text-align: center; padding: 60px 20px 40px; }
    .lobby-title {
        font-size: 3rem; font-weight: 900; letter-spacing: -2px;
        background: linear-gradient(135deg, #f0b429, #e8436a);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        margin: 0;
    }
    .lobby-sub { color: rgba(255,255,255,.45); font-size: 1rem; margin: 10px 0 0; }

    .monster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 20px; max-width: 900px; margin: 0 auto; padding: 0 20px 60px;
    }

    .monster-card {
        background: linear-gradient(145deg, #1a1a2e, #16213e);
        border: 1.5px solid rgba(255,255,255,.08);
        border-radius: 20px; padding: 32px 28px;
        position: relative; overflow: hidden;
        transition: border-color .25s, transform .2s;
    }
    .monster-card::before {
        content: ""; position: absolute;
        width: 300px; height: 300px; border-radius: 50%;
        background: radial-gradient(circle, rgba(232,67,106,.15) 0%, transparent 70%);
        top: -120px; left: 50%; transform: translateX(-50%);
        pointer-events: none;
    }
    .monster-card:hover { border-color: #e8436a55; transform: translateY(-4px); }

    .monster-sprite {
        font-size: 4.5rem; line-height: 1; display: block;
        text-align: center; margin-bottom: 16px;
        filter: drop-shadow(0 0 24px rgba(232,67,106,.5));
        animation: float 3s ease-in-out infinite;
    }
    @@keyframes float {
        0%,100% { transform: translateY(0); }
        50%      { transform: translateY(-10px); }
    }

    .monster-name { font-size: 1.3rem; font-weight: 900; color: #f0b429; text-align:center; margin: 0 0 8px; }
    .monster-desc { font-size: .8rem; color: rgba(255,255,255,.5); line-height: 1.6; margin: 0 0 20px; text-align:center; }

    .wave-compare {
        display: grid; grid-template-columns: 1fr auto 1fr;
        gap: 10px; align-items: center; margin-bottom: 20px;
    }
    .wave-box {
        background: rgba(255,255,255,.05); border-radius: 12px;
        padding: 12px 14px;
    }
    .wave-box-title { font-size: .65rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .08em; opacity: .5; margin-bottom: 8px; }
    .wave-stat { display: flex; justify-content: space-between;
        font-size: .75rem; margin-bottom: 4px; }
    .wave-stat-val { font-weight: 700; }
    .wave-arrow { font-size: 1.2rem; text-align: center; opacity: .4; }

    .xp-badge {
        display: block; text-align: center;
        background: rgba(240,180,41,.12); border: 1px solid rgba(240,180,41,.35);
        color: #f0b429; border-radius: 50px; padding: 5px 0;
        font-size: .82rem; font-weight: 700; margin-bottom: 20px;
    }
    .waves-badge {
        display: block; text-align: center; font-size: .75rem;
        color: rgba(255,255,255,.4); margin-bottom: 8px;
    }
    .level-note { text-align:center; font-size:.72rem; opacity:.4; margin-bottom:16px; }

    .btn-challenge {
        width: 100%; background: linear-gradient(135deg, #e8436a, #c0392b);
        color: white; border: none; border-radius: 14px; padding: 14px;
        font-size: 1rem; font-weight: 800; cursor: pointer;
        font-family: "Syne", sans-serif; letter-spacing: .04em;
        transition: opacity .2s, transform .15s;
        box-shadow: 0 6px 24px rgba(232,67,106,.35);
    }
    .btn-challenge:hover { opacity: .9; transform: scale(1.02); }
</style>

<div class="lobby-hero">
    <h1 class="lobby-title">⚔️ Battle Arena</h1>
    <p class="lobby-sub">Prove your worth — stats shown are scaled to your current level</p>
</div>

<div class="monster-grid">
    @foreach (var e in entries)
    {
        <div class="monster-card">
            <span class="monster-sprite">@e.Icon</span>
            <h3 class="monster-name">@e.Name</h3>
            <p class="monster-desc">@e.Description</p>

            <div class="level-note">Scaled to your Level @e.PlayerLevel</div>

            <!-- Wave 1 vs Wave 5 stat preview -->
            <div class="wave-compare">
                <div class="wave-box">
                    <div class="wave-box-title" style="color:#00b89c;">Wave 1</div>
                    <div class="wave-stat"><span>❤️ HP</span>  <span class="wave-stat-val">@e.W1HP</span></div>
                    <div class="wave-stat"><span>⚔️ ATK</span> <span class="wave-stat-val">@e.W1ATK</span></div>
                    <div class="wave-stat"><span>🛡️ ARM</span> <span class="wave-stat-val">@e.W1ARM</span></div>
                    <div class="wave-stat"><span>⚡ SPD</span> <span class="wave-stat-val">@e.W1SPD</span></div>
                </div>
                <div class="wave-arrow">→</div>
                <div class="wave-box">
                    <div class="wave-box-title" style="color:#e8436a;">Wave @e.TotalWaves</div>
                    <div class="wave-stat"><span>❤️ HP</span>  <span class="wave-stat-val" style="color:#e8436a;">@e.WLastHP</span></div>
                    <div class="wave-stat"><span>⚔️ ATK</span> <span class="wave-stat-val" style="color:#e8436a;">@e.WLastATK</span></div>
                    <div class="wave-stat"><span>🛡️ ARM</span> <span class="wave-stat-val" style="color:#e8436a;">@e.WLastARM</span></div>
                    <div class="wave-stat"><span>⚡ SPD</span> <span class="wave-stat-val" style="color:#e8436a;">@e.WLastSPD</span></div>
                </div>
            </div>

            <span class="waves-badge">@e.TotalWaves waves · HP carries over · no healing</span>
            <span class="xp-badge">Up to +@e.TotalXP XP for full clear</span>

            <form asp-action="Start" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="monsterId" value="test_unit" />
                <button type="submit" class="btn-challenge">⚔️ Enter Gauntlet</button>
            </form>
        </div>
    }
</div>
