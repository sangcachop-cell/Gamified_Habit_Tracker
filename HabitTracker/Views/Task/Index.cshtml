@model List<HabitTracker.Models.Task>

<h3>🎯 Your Tasks</h3>

<a href="/Task/Create" class="btn btn-primary mb-3">
    + Create Task
</a>

@foreach (var task in Model)
{
    var today = DateTime.Today;

    var isDone = Context.RequestServices
        .GetService<HabitTracker.Data.AppDbContext>()
        .TaskLogs.Any(x => x.TaskId == task.Id && x.Date == today);

    <div class="card p-3 mb-3 shadow-sm
            @(isDone ? "border-success" : "")">

        <div class="d-flex justify-content-between">

            <div>
                <h5>@task.Title</h5>

                <p class="text-muted">
                    📌 Type: @task.Type <br />
                    ⭐ XP: @task.XP <br />
                    ⏰ Deadline: @(task.Deadline?.ToString("yyyy-MM-dd HH:mm") ?? "None")
                </p>
            </div>

            <div>
                @if (!isDone)
                {
                    <a href="/Task/Complete/@task.Id"
                       class="btn btn-success">
                        ✔ Done
                    </a>
                }
                else
                {
                    <span class="badge bg-success">Done</span>
                }

                <a href="/Task/Delete/@task.Id"
                   class="btn btn-danger mt-2">
                    Delete
                </a>
            </div>

        </div>
    </div>
}