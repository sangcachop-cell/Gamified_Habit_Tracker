@* Views/Quest/Index.cshtml *@
@model List<HabitTracker.Models.Quest>

@{
    ViewData["Title"] = "Nhiệm vụ hôm nay";
    var completedIds = ViewBag.CompletedTodayIds as List<int> ?? new List<int>();
}

<div class="container py-4">
    <h2 class="mb-1">⚔️ Nhiệm vụ của bạn</h2>
    <p class="text-muted mb-4">Tick vào nhiệm vụ đã hoàn thành và nhấn <strong>Xác nhận</strong></p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["NewBadge"] != null)
    {
        <div class="alert alert-warning">@TempData["NewBadge"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @* Filter *@
    <form method="get" class="row g-2 mb-4">
        <div class="col-auto">
            <select name="category" class="form-select" onchange="this.form.submit()">
                <option value="">📂 Tất cả danh mục</option>
                @foreach (var cat in ViewBag.Categories as string[])
                {
                    <option value="@cat" selected="@(ViewBag.SelectedCategory == cat)">@cat</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <select name="difficulty" class="form-select" onchange="this.form.submit()">
                <option value="">⚡ Độ khó</option>
                <option value="Easy" selected="@(ViewBag.SelectedDifficulty == "Easy")">🟢 Dễ</option>
                <option value="Medium" selected="@(ViewBag.SelectedDifficulty == "Medium")">🟡 Trung bình</option>
                <option value="Hard" selected="@(ViewBag.SelectedDifficulty == "Hard")">🔴 Khó</option>
            </select>
        </div>
        <div class="col-auto">
            <select name="frequency" class="form-select" onchange="this.form.submit()">
                <option value="">🔁 Tần suất</option>
                <option value="Daily" selected="@(ViewBag.SelectedFrequency == "Daily")">Hàng ngày</option>
                <option value="Weekly" selected="@(ViewBag.SelectedFrequency == "Weekly")">Hàng tuần</option>
                <option value="Monthly" selected="@(ViewBag.SelectedFrequency == "Monthly")">Hàng tháng</option>
            </select>
        </div>
    </form>

    @* Danh sách Quest *@
    <form asp-action="Confirm" method="post">
        <div class="row g-3">
            @foreach (var quest in Model)
            {
                var isDone = completedIds.Contains(quest.Id);
                var diffColor = quest.Difficulty == "Easy" ? "success" : quest.Difficulty == "Medium" ? "warning" : "danger";

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm @(isDone ? "border-success bg-light" : "")">
                        <div class="card-body d-flex align-items-start gap-3">
                            <div class="form-check mt-1">
                                <input class="form-check-input" type="checkbox"
                                       name="questIds" value="@quest.Id"
                                       id="quest_@quest.Id"
                                       @(isDone ? "checked disabled" : "")>
                            </div>
                            <div class="flex-grow-1">
                                <label class="fw-semibold @(isDone ? "text-decoration-line-through text-muted" : "")"
                                       for="quest_@quest.Id">
                                    @quest.Icon @quest.Name
                                </label>
                                <div class="mt-1">
                                    <span class="badge bg-@diffColor">@quest.Difficulty</span>
                                    <span class="badge bg-secondary">@quest.Category</span>
                                    <span class="badge bg-info text-dark">@quest.Frequency</span>
                                </div>
                                <div class="mt-1 text-warning fw-bold">+@quest.XPReward XP</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 text-end">
            <button type="submit" class="btn btn-primary btn-lg px-5">
                ✅ Xác nhận hoàn thành
            </button>
        </div>
    </form>
</div>