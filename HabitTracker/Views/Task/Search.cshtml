@model List<HabitTracker.Models.Quest>
@{
    ViewData["Title"] = "Tìm kiếm Quest";
}
<style>
    :root {
        --ink: #0a0a12;
        --paper: #f5f3ef;
        --violet: #5c3dde;
        --gold: #f0b429;
        --rose: #e8436a;
        --teal: #00b89c;
        --soft: #edeaf5
    }

    body {
        background: var(--paper);
        font-family: "DM Sans",sans-serif
    }

    h1, h2, h3, h4 {
        font-family: "Syne",sans-serif
    }

    .search-hero {
        background: var(--ink);
        border-radius: 20px;
        padding: 32px 36px;
        margin-bottom: 28px;
        position: relative;
        overflow: hidden
    }

        .search-hero::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle,rgba(92,61,222,.4),transparent 70%);
            top: -150px;
            right: -100px
        }

        .search-hero h2 {
            font-size: 1.6rem;
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
            margin-bottom: 20px;
            position: relative;
            z-index: 2
        }

    .search-form {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        position: relative;
        z-index: 2
    }

    .search-input {
        flex: 1;
        min-width: 220px;
        padding: 12px 18px;
        border: none;
        border-radius: 50px;
        font-family: "DM Sans",sans-serif;
        font-size: .95rem;
        outline: none;
        background: white
    }

    .search-select {
        padding: 12px 16px;
        border: none;
        border-radius: 50px;
        font-family: "DM Sans",sans-serif;
        font-size: .88rem;
        background: white;
        outline: none;
        cursor: pointer
    }

    .btn-search {
        padding: 12px 28px;
        background: var(--violet);
        color: white;
        border: none;
        border-radius: 50px;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .9rem;
        cursor: pointer;
        transition: background .2s
    }

        .btn-search:hover {
            background: #4a2fc0
        }

    .btn-reset {
        padding: 12px 20px;
        background: rgba(255,255,255,.15);
        color: white;
        border: 1.5px solid rgba(255,255,255,.25);
        border-radius: 50px;
        font-weight: 500;
        font-size: .88rem;
        text-decoration: none;
        transition: all .2s
    }

        .btn-reset:hover {
            background: rgba(255,255,255,.25);
            color: white
        }
    /* active tags */
    .filter-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 20px
    }

    .ftag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: white;
        border: 1.5px solid rgba(0,0,0,.1);
        padding: 6px 14px;
        border-radius: 50px;
        font-size: .8rem;
        font-weight: 600
    }
    /* results */
    .results-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px
    }

        .results-bar span {
            font-size: .88rem;
            color: #888
        }

        .results-bar strong {
            color: var(--violet)
        }

    .qcard {
        background: white;
        border-radius: 16px;
        border: 1.5px solid rgba(0,0,0,.07);
        padding: 22px;
        margin-bottom: 14px;
        transition: all .25s;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px
    }

        .qcard:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(0,0,0,.09);
            border-color: rgba(92,61,222,.25)
        }

    .qcard-left {
        flex: 1
    }

    .q-head {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px
    }

    .q-ico {
        font-size: 1.4rem
    }

    .q-name {
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: 1rem
    }

    .q-desc {
        font-size: .87rem;
        color: #777;
        line-height: 1.6;
        margin-bottom: 12px
    }

    .q-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap
    }

    .qtag {
        padding: 3px 10px;
        border-radius: 50px;
        font-size: .73rem;
        font-weight: 600
    }

    .qtag-cat {
        background: #edeaf5;
        color: var(--violet)
    }

    .qtag-easy {
        background: #e2f5e2;
        color: #2e7d2e
    }

    .qtag-medium {
        background: #fff5d6;
        color: #b07800
    }

    .qtag-hard {
        background: #fde8ed;
        color: #c0392b
    }

    .qtag-freq {
        background: #f0f4ff;
        color: #4457aa
    }

    .qcard-right {
        text-align: right;
        flex-shrink: 0
    }

    .xp-big {
        font-family: "Syne",sans-serif;
        font-weight: 800;
        font-size: 1.3rem;
        color: var(--violet)
    }

    .xp-label {
        font-size: .73rem;
        color: #aaa;
        margin-bottom: 10px
    }

    .btn-go {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--ink);
        color: white;
        padding: 8px 16px;
        border-radius: 50px;
        font-family: "Syne",sans-serif;
        font-weight: 700;
        font-size: .8rem;
        text-decoration: none;
        transition: background .2s
    }

        .btn-go:hover {
            background: var(--violet);
            color: white
        }
    /* empty */
    .empty {
        text-align: center;
        padding: 64px 24px;
        background: white;
        border-radius: 20px
    }

    .empty-emoji {
        font-size: 3.5rem;
        margin-bottom: 16px
    }
</style>

<div style="padding:8px 0 48px">

    <!-- Search Hero -->
    <div class="search-hero">
        <h2>🔍 Tìm kiếm Quest</h2>
        <form method="get" action="/Task/search" class="search-form">
            <input type="text" name="q" class="search-input" placeholder="Tìm tên quest..." value="@ViewBag.SearchQuery" />

            <select name="category" class="search-select">
                <option value="">📂 Tất cả</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat" selected="@(ViewBag.SelectedCategory == cat ? "selected" : null)">@cat</option>
                    }
                }
            </select>

            <select name="difficulty" class="search-select">
                <option value="">⚡ Độ khó</option>
                @if (ViewBag.Difficulties != null)
                {
                    foreach (var d in ViewBag.Difficulties)
                    {
                        <option value="@d" selected="@(ViewBag.SelectedDifficulty == d ? "selected" : null)">@d</option>
                    }
                }
            </select>

            <button type="submit" class="btn-search">🔍 Tìm</button>
            <a href="/Task/search" class="btn-reset">↺ Reset</a>
        </form>
    </div>

    <!-- Active filters -->
    @{
        bool hasFilters = !string.IsNullOrEmpty(ViewBag.SearchQuery as string) ||
        !string.IsNullOrEmpty(ViewBag.SelectedCategory as string) ||
        !string.IsNullOrEmpty(ViewBag.SelectedDifficulty as string);
    }
    @if (hasFilters)
    {
        <div class="filter-tags">
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery as string))
            {
                <span class="ftag">🔍 "@ViewBag.SearchQuery"</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.SelectedCategory as string))
            {
                <span class="ftag">📂 @ViewBag.SelectedCategory</span>
            }
            @if (!string.IsNullOrEmpty(ViewBag.SelectedDifficulty as string))
            {
                <span class="ftag">⚡ @ViewBag.SelectedDifficulty</span>
            }
        </div>
    }

    <!-- Results -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="results-bar">
            <span>Tìm thấy <strong>@Model.Count</strong> quest</span>
            <a href="/Task" style="font-size:.85rem;color:var(--violet);text-decoration:none;font-weight:600">📋 Xem tất cả →</a>
        </div>

        foreach (var quest in Model)
        {
            var diffTag = quest.Difficulty == "Easy" ? "qtag-easy" : quest.Difficulty == "Medium" ? "qtag-medium" : "qtag-hard";
            <div class="qcard">
                <div class="qcard-left">
                    <div class="q-head">
                        <span class="q-ico">@quest.Icon</span>
                        <span class="q-name">@quest.Name</span>
                    </div>
                    @if (!string.IsNullOrEmpty(quest.Description))
                    {
                        <div class="q-desc">@quest.Description</div>
                    }
                    <div class="q-tags">
                        <span class="qtag qtag-cat">@quest.Category</span>
                        <span class="qtag @diffTag">@quest.Difficulty</span>
                        <span class="qtag qtag-freq">@quest.Frequency</span>
                    </div>
                </div>
                <div class="qcard-right">
                    <div class="xp-label">Phần thưởng</div>
                    <div class="xp-big">+@quest.XPReward XP</div>
                    <a href="/Task" class="btn-go">▶ Làm ngay</a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty">
            <div class="empty-emoji">🔍</div>
            <h4 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:8px">Không tìm thấy quest nào</h4>
            <p style="color:#aaa;font-size:.9rem;margin-bottom:24px">Thử thay đổi từ khoá hoặc bộ lọc</p>
            <a href="/Task/search" style="display:inline-flex;align-items:center;gap:6px;background:var(--ink);color:white;padding:11px 24px;border-radius:50px;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;text-decoration:none">↺ Xóa bộ lọc</a>
        </div>
    }
</div>
